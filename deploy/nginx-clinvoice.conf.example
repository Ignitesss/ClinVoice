# Пример для Linux: скопируйте в /etc/nginx/sites-available/ и подключите sites-enabled.
# Предполагается сборка фронта: `cd frontend && npm run build` → статика из frontend/dist.
# TLS может терминировать Cloudflare; локально можно слушать 8080 по HTTP.

upstream clinvoice_api {
    server 127.0.0.1:8000;
    keepalive 32;
}

server {
    listen 8080;
    server_name _;

    root /opt/clinvoice/frontend/dist;
    index index.html;

    client_max_body_size 32m;

    location /api/ {
        proxy_pass http://clinvoice_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    location /ws/ {
        proxy_pass http://clinvoice_api;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
